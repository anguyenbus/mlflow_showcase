# Zhipu AI Configuration
# Get your API key from: https://open.bigmodel.cn/
ZHIPU_API_KEY=your_zhipu_api_key_here

# MLflow Tracking Configuration
# Default uses local SQLite backend
MLFLOW_TRACKING_URI=sqlite:///mlflow.db

# Optional: Use remote MLflow tracking server
# MLFLOW_TRACKING_URI=http://localhost:5000
# MLFLOW_TRACKING_URI=databricks

# Garak Evaluation Configuration
# Garak uses ZHIPU_API_KEY for Zhipu AI model evaluation
# Default Zhipu model for Garak evaluations
GARAK_DEFAULT_MODEL=glm-5-flash

# Garak output directory (relative to project root)
GARAK_OUTPUT_DIR=garak_results
